DATABASE_URL="postgresql://postgres:password@localhost:5432/vyntrise_auth?schema=public"
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
FRONTEND_URL=http://localhost:3001

# Server
PORT=3021
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins for cross-origin requests
# Development: Use your local URLs
# Production: Use your actual domain URLs (e.g., https://auth.vyntrise.com,https://sms.vyntrise.com)
# Use * only for development (NOT RECOMMENDED for production)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Email Provider Options:
# - "console": Logs emails to console (development default)
# - "smtp": Generic SMTP server
# - "gmail": Gmail-specific configuration
EMAIL_PROVIDER=console

# ===== SMTP Configuration (when EMAIL_PROVIDER=smtp) =====
 

# ===== Gmail Configuration (when EMAIL_PROVIDER=gmail) =====
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=your-gmail-app-password
