# Vyntrise Auth Configuration

# Auth Service URL
NEXT_PUBLIC_AUTH_URL=https://auth.vyntrise.com

# Your Platform ID (get from https://auth.vyntrise.com/admin/platforms)
NEXT_PUBLIC_PLATFORM_ID=your-platform-uuid-here

# JWT Secret (MUST match the auth service secret)
JWT_SECRET=same-secret-as-auth-service
